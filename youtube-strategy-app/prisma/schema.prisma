// YouTube Strategy App — Prisma Schema
// Ejecutar después de editar: npx prisma generate
// Para crear la DB: npx prisma migrate dev --name init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector", schema: "public")]
}

// ─── Auth (NextAuth.js v5 adapter) ───────────────────────────

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  image      String?
  plan       String   @default("free")
  createdAt  DateTime @default(now())
  lastActive DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  channels  Channel[]
  auditLogs AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Domain ─────────────────────────────────────────────

model Channel {
  id               String   @id @default(cuid())
  userId           String
  youtubeChannelId String?
  niche            String?
  score            Float?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  nicheEvaluations NicheEvaluation[]
  contentIdeas     ContentIdea[]
  actionItems      ActionItem[]

  @@map("channels")
}

model NicheEvaluation {
  id             String   @id @default(cuid())
  channelId      String
  criteriaJson   Json
  totalScore     Float
  recommendation String
  createdAt      DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("niche_evaluations")
}

model ContentIdea {
  id           String   @id @default(cuid())
  channelId    String
  title        String
  hook         String?  @db.Text
  description  String?  @db.Text
  outlierScore Float?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("content_ideas")
}

model ActionItem {
  id          String    @id @default(cuid())
  channelId   String
  phase       Int       @default(0)
  step        Int
  description String    @db.Text
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("action_items")
}

// ─── Security ────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  ipHash    String?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@map("audit_logs")
}

// ─── RAG — Knowledge Embeddings ──────────────────────────────
// Nota: el campo embedding usa pgvector (vector(1536)).
// Requiere la extensión pgvector instalada en PostgreSQL.
// Para instalar: CREATE EXTENSION IF NOT EXISTS vector;

model KnowledgeEmbedding {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceType String   @db.VarChar(50)
  sourceId   String?
  author     String?  @db.VarChar(50)
  chunkText  String   @db.Text
  embedding  Unsupported("vector(1536)")?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([author])
  @@map("knowledge_embeddings")
}
